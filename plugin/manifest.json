{
  "name": "Smart Playlist",
  "author": "dieterpl",
  "version": "1.0.0",
  "description": "Generates dynamic Spotify-style playlists: genre-aware daily mixes, On Repeat, Release Radar, Loved Songs Mix, and taste-sorted Artist/Genre Radios.",
  "permissions": {
    "scheduler": {
      "reason": "Required to periodically generate and update smart playlists."
    },
    "subsonicapi": {
      "reason": "Required to interact with the music library and create playlists."
    },
    "users": {
      "reason": "Required for SubsonicAPI access."
    },
    "kvstore": {
      "reason": "Required to track the last update time for daily/weekly cycles."
    }
  },
  "config": {
    "schema": {
      "type": "object",
      "properties": {
        "prefix": {
          "type": "string",
          "title": "Playlist Prefix",
          "default": "✨ "
        },
        "dailySize": {
          "type": "integer",
          "title": "Daily Mix Size",
          "default": 30,
          "minimum": 1
        },
        "weeklySize": {
          "type": "integer",
          "title": "Weekly Mix Size",
          "default": 25,
          "minimum": 1
        },
        "dailyMixCount": {
          "type": "integer",
          "title": "Number of Daily Mixes",
          "default": 3,
          "minimum": 1,
          "maximum": 6
        },
        "numArtistRadios": {
          "type": "integer",
          "title": "Number of Artist Radios",
          "default": 5,
          "minimum": 1,
          "maximum": 20
        },
        "artistRadioSize": {
          "type": "integer",
          "title": "Artist Radio Size",
          "default": 30,
          "minimum": 1
        },
        "numGenreRadios": {
          "type": "integer",
          "title": "Number of Genre Radios",
          "default": 3,
          "minimum": 1,
          "maximum": 10
        },
        "enableWeeklyDiscovery": {
          "type": "boolean",
          "title": "Enable Weekly Discovery",
          "default": true
        },
        "enableArtistRadio": {
          "type": "boolean",
          "title": "Enable Artist Radios",
          "default": true
        },
        "enableGenreRadio": {
          "type": "boolean",
          "title": "Enable Genre Radios",
          "default": true
        },
        "enableOnRepeat": {
          "type": "boolean",
          "title": "Enable On Repeat Playlist",
          "default": true
        },
        "enableReleaseRadar": {
          "type": "boolean",
          "title": "Enable Release Radar",
          "default": true
        },
        "enableLovedMix": {
          "type": "boolean",
          "title": "Enable Loved Songs Mix",
          "default": true
        }
      }
    }
  }
}
